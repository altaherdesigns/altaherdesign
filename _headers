# Cloudflare Pages headers — performance & security (both help SEO)

# Cache static assets aggressively (1 year) — faster repeat visits = better Core Web Vitals
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# CSS & JS
/assets/css/*
  Cache-Control: public, max-age=31536000, immutable
/assets/js/*
  Cache-Control: public, max-age=31536000, immutable

# HTML — revalidate so updates show quickly
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Security headers (Google rewards HTTPS + secure sites)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
